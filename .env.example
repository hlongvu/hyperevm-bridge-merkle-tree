# Wallet that deploys contracts (needs gas on both chains)
DEPLOYER_PRIVATE_KEY=0x...

# Separate wallet the relayer uses to sign + submit txs (needs gas on both chains)
RELAYER_PRIVATE_KEY=0x...

# Alchemy or Infura Sepolia endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# HyperEVM testnet RPC
HYPEREVM_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
